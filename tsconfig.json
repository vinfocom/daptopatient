{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true
  },
  "include": [
    "App.tsx",
    "index.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "app",
    "components",
    "constants",
    "hooks",
    "scripts"
  ]
}

{
  "expo": {
    "name": "Dapto Patient",
    "slug": "daptopatient",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/daptopatient-icon.png",
    "scheme": "daptopatient",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/daptopatient-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.harshit.daptopatient",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow access to camera to send photos in chat.",
        "NSPhotoLibraryUsageDescription": "Allow access to your photos to send images in chat.",
        "NSPhotoLibraryAddUsageDescription": "Allow saving images to your library."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ],
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/daptopatient-android-foreground.png",
        "backgroundImage": "./assets/images/daptopatient-android-background.png",
        "monochromeImage": "./assets/images/daptopatient-android-monochrome.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.harshit.daptopatient"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/daptopatient-favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "",
      "socketUrl": "",
      "eas": {
        "projectId": "f537bad5-c591-472f-b541-4ab0080f40f7"
      }
    },
    "experiments": {
      "reactCompiler": true
    },
    "owner": "harshittripathi"
  }
}
